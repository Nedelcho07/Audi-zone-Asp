@model IEnumerable<Audi_zone.Models.Product>

@{
    ViewData["Title"] = "Index";
}

<div class="row">
    <div class="col-md-3">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="bi bi-funnel"></i> Филтри</h5>
            </div>
            <div class="card-body">
                <form asp-action="Index" method="get">
                    <div class="mb-4">
                        <label class="fw-bold mb-2">Категория</label>
                        <select name="categoryId" class="form-select" onchange="this.form.submit()">
                            <option value="">Всички категории</option>
                            <option value="1">Двигател</option>
                            <option value="2">Спирачна система</option>
                            <option value="3">Електроника</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="fw-bold mb-2">Модел автомобил</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="modelId" id="m1" value="1">
                            <label class="form-check-label" for="m1">Audi A3</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="modelId" id="m2" value="2">
                            <label class="form-check-label" for="m2">Audi A4</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="modelId" id="m3" value="3">
                            <label class="form-check-label" for="m3">Audi Q7</label>
                        </div>
                    </div>

                    <a href="/Products" class="btn btn-sm btn-link text-danger p-0">Изчисти филтрите</a>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Налични части</h2>
            <span class="text-muted">Намерени: @(Model != null ? Model.Count() : 0) резултата</span>
        </div>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 product-card">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x200?text=Audi+Part" : item.ImageUrl)"
                                 class="card-img-top" alt="@item.Name">

                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <small class="text-danger fw-bold">ID: @item.Id</small>
                                    <small class="text-muted">@item.CarModel?.Name</small>
                                </div>
                                <h5 class="card-title mt-2">@item.Name</h5>
                                <p class="card-text text-truncate small text-muted">@item.Description</p>
                                <h4 class="text-dark fw-bold">@item.Price.ToString("F2") лв.</h4>
                            </div>
                            <div class="card-footer bg-white border-0 d-grid pb-3">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-dark">Детайли</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Няма намерени продукти по избраните критерии.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .product-card {
        transition: transform 0.2s;
    }

        .product-card:hover {
            transform: translateY(-5px);
            border: 1px solid #dc3545 !important;
        }
</style>