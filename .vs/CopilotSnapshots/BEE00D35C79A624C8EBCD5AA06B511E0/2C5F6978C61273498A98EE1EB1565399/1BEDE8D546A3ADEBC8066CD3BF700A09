@model Audi_zone.Models.Product

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Product</h4>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <img src="@(string.IsNullOrEmpty(Model.ImageURL) ? "https://via.placeholder.com/400x400?text=Audi+Part" : Model.ImageURL)" 
                 alt="@Model.Name" class="img-fluid rounded" style="width: 100%; height: 400px; object-fit: cover;">
        </div>
        <div class="col-md-8">
            <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Code)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Code)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Models)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Models.Id)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ImageURL)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ImageURL)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DateRegOn)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DateRegOn)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ProductTypes)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ProductTypes.Id)
        </dd>
        </dl>
        </div>
    </div>
</div>
<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
    <form asp-controller="Carts" asp-action="Create" method="post">
        <input type ="hidden" name="ProductId" value="@Model.Id" />
        <label for="quantity">Количество: </label>
        <input type="number" id="quantity" name="Quantity" value="1" min="1" />
        <button type ="submit" > 
            Добави в количката 
        </button>
    </form> 
</div>
