@model IEnumerable<Audi_zone.Models.Cart>

@model IEnumerable<Audi_zone.Models.Cart>

@{
    ViewData["Title"] = "Моята количка";
    var cartItems = Model?.ToList() ?? new List<Audi_zone.Models.Cart>();
    var grandTotal = cartItems.Sum(x => x.Quantity * x.Products.Price);
    var userOrders = ViewBag.UserOrders as List<Audi_zone.Models.Order> ?? new List<Audi_zone.Models.Order>();
}

@if (TempData["OrderMessage"] != null)
{
    <div class="alert alert-success shadow-sm border-0 mb-4">
        <h5 class="mb-1"><i class="bi bi-check-circle me-2"></i>@TempData["OrderMessage"]</h5>
        @if (TempData["OrderedItems"] != null)
        {
            <hr />
            <div class="small text-dark">@Html.Raw(TempData["OrderedItems"])</div>
            <div class="fw-bold mt-2">Обща сума: @TempData["OrderedTotal"]</div>
        }
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-cart3 me-2 text-danger"></i>Моята количка</h2>
    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark btn-sm">Продължи пазаруването</a>
</div>

@if (!cartItems.Any())
{
    <div class="card shadow-sm border-0 text-center py-5">
        <div class="card-body">
            <i class="bi bi-cart-x text-danger" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Количката е празна</h4>
            <p class="text-muted">Добави продукти, за да ги видиш тук.</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-dark">Към продуктите</a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Продукт</th>
                        <th class="text-center">Количество</th>
                        <th class="text-end">Ед. цена</th>
                        <th class="text-end">Общо</th>
                        <th class="text-center">Действие</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in cartItems)
                    {
                        var productImage = string.IsNullOrEmpty(item.Products.ImageURL)
                            ? "https://via.placeholder.com/120x120?text=Audi+Part"
                            : item.Products.ImageURL;
                        var lineTotal = item.Quantity * item.Products.Price;

                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@productImage" alt="@item.Products.Name" class="cart-image rounded" />
                                    <div>
                                        <div class="fw-bold">@item.Products.Name</div>
                                        <small class="text-muted">ID: @item.Products.Id</small>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center fw-bold">@item.Quantity</td>
                            <td class="text-end">@item.Products.Price.ToString("F2") лв.</td>
                            <td class="text-end fw-bold">@lineTotal.ToString("F2") лв.</td>
                            <td class="text-center">
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Премахни</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm border-0 mt-4">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h5 class="mb-0">Крайна сума:</h5>
                <h4 class="mb-0 text-danger fw-bold">@grandTotal.ToString("F2") лв.</h4>
            </div>
            <form asp-action="PlaceOrder" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger fw-bold px-4">
                    <i class="bi bi-bag-check me-2"></i>Поръчай
                </button>
            </form>
        </div>
    </div>
}

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Моите поръчки</h5>
    </div>
    <div class="card-body">
        @if (!userOrders.Any())
        {
            <p class="text-muted mb-0">Все още нямаш направени поръчки.</p>
        }
        else
        {
            @foreach (var order in userOrders)
            {
                <div class="border rounded p-3 mb-3 order-item">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong>Поръчка #@order.Id</strong>
                        <small class="text-muted">@order.OrderedOn.ToString("dd.MM.yyyy HH:mm")</small>
                    </div>
                    <div class="small">@Html.Raw(order.OrderedItems)</div>
                    <div class="fw-bold text-danger mt-2">Обща сума: @order.TotalPrice.ToString("F2") лв.</div>
                </div>
            }
        }
    </div>
</div>

<style>
    .cart-image {
        width: 72px;
        height: 72px;
        object-fit: cover;
    }

    .order-item:last-child {
        margin-bottom: 0 !important;
    }
</style>
