@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="login-wrapper">
    <div class="login-container">
        <!-- Left Side - Branding -->
        <div class="login-brand">
            <div class="brand-content">
                <h1 class="brand-title">
                    <span class="brand-icon">🚗</span>
                    Audi Zone
                </h1>
                <p class="brand-subtitle">Premium Automotive Experience</p>
                <div class="brand-features">
                    <div class="feature">
                        <span class="feature-icon">✓</span>
                        <span>Quality Products</span>
                    </div>
                    <div class="feature">
                        <span class="feature-icon">✓</span>
                        <span>Secure Checkout</span>
                    </div>
                    <div class="feature">
                        <span class="feature-icon">✓</span>
                        <span>Fast Delivery</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side - Login Form -->
        <div class="login-form-section">
            <div class="form-header">
                <h2>Welcome Back</h2>
                <p>Sign in to your account</p>
            </div>

            <form id="account" method="post" class="login-form">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    <strong>Oops!</strong> Please correct the errors below.
                </div>

                <div class="form-group">
                    <label asp-for="Input.UserName" class="form-label">Username or Email</label>
                    <div class="input-wrapper">
                        <span class="input-icon">👤</span>
                        <input asp-for="Input.UserName" 
                               class="form-control" 
                               autocomplete="username" 
                               aria-required="true" 
                               placeholder="Enter your username or email" />
                    </div>
                    <span asp-validation-for="Input.UserName" class="error-message"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <div class="input-wrapper">
                        <span class="input-icon">🔐</span>
                        <input asp-for="Input.Password" 
                               class="form-control" 
                               autocomplete="current-password" 
                               aria-required="true" 
                               placeholder="Enter your password" 
                               type="password" />
                    </div>
                    <span asp-validation-for="Input.Password" class="error-message"></span>
                </div>

                <div class="form-check remember-me">
                    <input class="form-check-input" type="checkbox" asp-for="Input.RememberMe" id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">
                        Remember me
                    </label>
                </div>

                <button id="login-submit" type="submit" class="btn-login">
                    Sign In
                </button>

                <div class="divider">
                    <span>Don't have an account?</span>
                </div>

                <div class="auth-links">
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="link-register">
                        Create Account
                    </a>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="link-forgot">
                        Forgot Password?
                    </a>
                </div>

                <div class="additional-links">
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">
                        Resend Email Confirmation
                    </a>
                </div>
            </form>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="external-login-section">
                    <div class="divider">
                        <span>Or continue with</span>
                    </div>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div class="external-providers">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" 
                                        class="btn-external" 
                                        name="provider" 
                                        value="@provider.Name" 
                                        title="Log in using your @provider.DisplayName account">
                                    @provider.DisplayName
                                </button>
                            }
                        </div>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Add some interactivity
        document.querySelectorAll('.form-control').forEach(input => {
            input.addEventListener('focus', function() {
                this.parentElement.classList.add('focused');
            });
            input.addEventListener('blur', function() {
                this.parentElement.classList.remove('focused');
            });
        });
    </script>
}
