<!DOCTYPE html>
@inject Audi_zone.Data.ApplicationDbContext DbContext
@inject Microsoft.AspNetCore.Identity.UserManager<Audi_zone.Models.Client> UserManager

@{
    var cartItemsCount = 0;
    if (User?.Identity?.IsAuthenticated ?? false)
    {
        var currentUserId = UserManager.GetUserId(User);
        cartItemsCount = DbContext.Carts
            .Where(c => c.ClientId == currentUserId)
            .Sum(c => (int?)c.Quantity) ?? 0;
    }
}

<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Audi-zone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand text-uppercase fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-car-front-fill me-2"></i>Audi-zone
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Products" asp-action="Index">Всички части</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Contacts">Контакти</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link text-light dropdown-toggle" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Мой профил">
                                    <i class="bi bi-person-circle me-1"></i>
                                    <span class="d-none d-sm-inline-block">Профил</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                                    <li>
                                        <a class="dropdown-item" href="/Identity/Account/Manage">
                                            <i class="bi bi-person-gear me-2 text-danger"></i>Моят профил
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Carts" asp-action="Index">
                                            <i class="bi bi-cart3 me-2 text-danger"></i>Количка <span class="badge bg-danger rounded-pill ms-2">@cartItemsCount</span>
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-area="Identity" asp-page="/Account/Logout" onclick="document.getElementById('logoutForm').submit(); return false;">
                                            <i class="bi bi-box-arrow-right me-2"></i>Изход
                                        </a>
                                        <form id="logoutForm" method="post" asp-area="Identity" asp-page="/Account/Logout"></form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="Identity" asp-page="/Account/Login">Вход</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-5">
        <div class="container py-3 text-center">
            &copy; 2026 - Audi-zone - Всички права запазени.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>