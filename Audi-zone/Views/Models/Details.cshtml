@model Audi_zone.Models.Model

@{
    ViewData["Title"] = "Детайли за модел";
}

<div class="page-heading mb-4">
    <span class="eyebrow">Админ</span>
    <h1 class="h2 mb-1">Детайли за модел</h1>
    <p class="text-muted mb-0">Преглед на запис за модел Audi.</p>
</div>

<div class="surface p-4">
    <div class="detail-stat-grid mb-4">
        <div class="detail-stat">
            <span>Модел</span>
            <strong>@Model.ModelName</strong>
        </div>
        <div class="detail-stat">
            <span>Дата</span>
            <strong>@Model.DateRegOn.ToString("dd.MM.yyyy")</strong>
        </div>
    </div>
    <div class="form-actions">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-danger">
            <i class="bi bi-pencil me-2"></i>Редактирай
        </a>
        <a asp-action="Index" class="btn btn-outline-dark">Назад</a>
    </div>
</div>
