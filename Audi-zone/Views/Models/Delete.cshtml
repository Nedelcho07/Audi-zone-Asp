@model Audi_zone.Models.Model

@{
    ViewData["Title"] = "Изтриване на модел";
}

<div class="page-heading mb-4">
    <span class="eyebrow">Админ</span>
    <h1 class="h2 mb-1">Изтриване на модел</h1>
    <p class="text-muted mb-0">Потвърди премахването на модела от каталога.</p>
</div>

<div class="surface p-4">
    <div class="alert alert-warning border-0 mb-4">
        <i class="bi bi-exclamation-triangle me-2"></i>Сигурен ли си, че искаш да изтриеш този модел?
    </div>
    <div class="detail-stat-grid mb-4">
        <div class="detail-stat">
            <span>Модел</span>
            <strong>@Model.ModelName</strong>
        </div>
        <div class="detail-stat">
            <span>Дата</span>
            <strong>@Model.DateRegOn.ToString("dd.MM.yyyy")</strong>
        </div>
    </div>

    <form asp-action="Delete" class="form-actions">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-2"></i>Изтрий
        </button>
        <a asp-action="Index" class="btn btn-outline-dark">Назад</a>
    </form>
</div>
