@model Audi_zone.Models.Model

@{
    ViewData["Title"] = "Нов модел";
}

<div class="page-heading mb-4">
    <span class="eyebrow">Админ</span>
    <h1 class="h2 mb-1">Нов модел</h1>
    <p class="text-muted mb-0">Добавяне на модел Audi към филтрите и каталога.</p>
</div>

<div class="surface p-4 admin-form">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-8">
                <label asp-for="ModelName" class="form-label fw-bold">Име на модел</label>
                <input asp-for="ModelName" class="form-control" />
                <span asp-validation-for="ModelName" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="DateRegOn" class="form-label fw-bold">Дата</label>
                <input asp-for="DateRegOn" class="form-control" />
                <span asp-validation-for="DateRegOn" class="text-danger"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-check2-circle me-2"></i>Създай
            </button>
            <a asp-action="Index" class="btn btn-outline-dark">Назад</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
