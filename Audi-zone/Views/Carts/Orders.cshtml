@model IEnumerable<Audi_zone.Models.Order>

@{
    ViewData["Title"] = "Моите поръчки";
    var orders = Model?.ToList() ?? new List<Audi_zone.Models.Order>();
}

<div class="page-heading d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
        <span class="eyebrow">Профил</span>
        <h1 class="h2 mb-1">Моите поръчки</h1>
        <p class="text-muted mb-0">История на направените поръчки в Audi-zone.</p>
    </div>
    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark">
        <i class="bi bi-arrow-left me-2"></i>Към продуктите
    </a>
</div>

@if (!orders.Any())
{
    <div class="empty-state">
        <i class="bi bi-bag-x text-danger"></i>
        <h2 class="h4 mt-3">Все още нямаш поръчки</h2>
        <p class="text-muted">Когато завършиш поръчка, тя ще се появи тук.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-dark">Разгледай части</a>
    </div>
}
else
{
    <div class="surface table-responsive">
        <table class="table table-modern align-middle mb-0">
            <thead>
                <tr>
                    <th>Поръчка</th>
                    <th>Дата</th>
                    <th class="text-end">Сума</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders)
                {
                    <tr>
                        <td>
                            <span class="fw-bold">#@order.Id</span>
                        </td>
                        <td>@order.OrderedOn.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-end fw-bold text-danger">@order.TotalPrice.ToString("F2") лв.</td>
                        <td class="text-end">
                            <a asp-action="OrderDetails" asp-route-id="@order.Id" class="btn btn-sm btn-outline-dark">
                                Детайли
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
