@model IEnumerable<Audi_zone.Models.Model>

@{
    ViewData["Title"] = "Начало";
}

<div class="p-5 mb-4 bg-dark text-white rounded-3 shadow-lg home-hero">
    <div class="container-fluid py-5 hero-overlay">
        <h1 class="display-5 fw-bold">Твоят доверен партньор за части Audi</h1>
        <p class="col-md-8 fs-4">Открий оригинални и алтернативни авточасти за всички модели на Audi. Бързо търсене, сигурна доставка.</p>

       
    </div>
</div>

<div class="container mt-5">
    <h3 class="mb-4 border-bottom pb-2">Избери своя модел</h3>
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var carModel in Model.Take(3))
            {
                <div class="col-md-3">
                    <div class="card h-100 shadow-sm text-center">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@carModel.ModelName</h5>
                            <p class="card-text text-muted">Оригинални части</p>
                            <a href="/Products?modelId=@carModel.Id" class="btn btn-outline-dark btn-sm">Виж частите</a>
                        </div>
                    </div>
                </div>
            }
        }

        <div class="col-md-3">
            <div class="card h-100 shadow-sm text-center bg-light">
                <div class="card-body d-flex align-items-center justify-content-center">
                    <a href="/Products" class="text-decoration-none text-dark fw-bold">Разгледай всички модели <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>
