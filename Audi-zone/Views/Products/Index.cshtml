@model IEnumerable<Audi_zone.Models.Product>

@{
    ViewData["Title"] = "Index";
}

<div class="row">
    <div class="col-md-3">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="bi bi-funnel"></i> Филтри</h5>
            </div>
            <div class="card-body">
                <form asp-action="Index" method="get" id="filterForm">
                    <div class="mb-4">
                        <label class="fw-bold mb-2">Категория</label>
                        <select name="categoryId" class="form-select" onchange="document.getElementById('filterForm').submit()">
                            <option value="">Всички категории</option>
                            @if (ViewBag.Categories != null)
                            {
                                @foreach (var category in ViewBag.Categories)
                                {
                                    if (Context.Request.Query["categoryId"].ToString() == category.Id.ToString())
                                    {
                                        <option value="@category.Id" selected>@category.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@category.Id">@category.Name</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="fw-bold mb-2">Модел автомобил</label>
                        <div class="form-check">
                            @if (string.IsNullOrEmpty(Context.Request.Query["modelId"]))
                            {
                                <input class="form-check-input" type="radio" name="modelId" id="m0" value="" checked>
                            }
                            else
                            {
                                <input class="form-check-input" type="radio" name="modelId" id="m0" value="">
                            }
                            <label class="form-check-label" for="m0">Всички модели</label>
                        </div>
                        @if (ViewBag.Models != null)
                        {
                            @foreach (var carModel in ViewBag.Models)
                            {
                                if (Context.Request.Query["modelId"].ToString() == carModel.Id.ToString())
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="modelId" id="m@carModel.Id" value="@carModel.Id" onchange="document.getElementById('filterForm').submit()" checked>
                                        <label class="form-check-label" for="m@carModel.Id">@carModel.ModelName</label>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="modelId" id="m@carModel.Id" value="@carModel.Id" onchange="document.getElementById('filterForm').submit()">
                                        <label class="form-check-label" for="m@carModel.Id">@carModel.ModelName</label>
                                    </div>
                                }
                            }
                        }
                    </div>

                    <a href="/Products" class="btn btn-sm btn-link text-danger p-0">Изчисти филтрите</a>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Налични части</h2>
            <span class="text-muted">Намерени: @(Model != null ? Model.Count() : 0) резултата</span>
        </div>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 product-card">
                            <img src="@(string.IsNullOrEmpty(item.ImageURL) ? "https://via.placeholder.com/300x200?text=Audi+Part" : item.ImageURL)"
                                 class="card-img-top" alt="@item.Name">

                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <small class="text-danger fw-bold">ID: @item.Id</small>
                                    <small class="text-muted">@item.Models?.ModelName</small>
                                </div>
                                <h5 class="card-title mt-2">@item.Name</h5>
                                <p class="card-text text-truncate small text-muted">@item.Description</p>
                                <h4 class="text-dark fw-bold">@item.Price.ToString("F2") лв.</h4>
                            </div>
                            <div class="card-footer bg-white border-0 d-grid pb-3">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-dark">Детайли</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Няма намерени продукти по избраните критерии.</p>
                </div>
            }
        </div>
    </div>
</div>

