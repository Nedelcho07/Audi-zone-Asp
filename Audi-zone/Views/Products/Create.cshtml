@model Audi_zone.Models.Product

@{
    ViewData["Title"] = "Нова част";
}

<div class="page-heading mb-4">
    <span class="eyebrow">Админ</span>
    <h1 class="h2 mb-1">Нова част</h1>
    <p class="text-muted mb-0">Добавяне на продукт към публичния каталог.</p>
</div>

<div class="surface p-4 admin-form">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Code" class="form-label fw-bold">Код</label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>
            <div class="col-md-8">
                <label asp-for="Name" class="form-label fw-bold">Име</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ModelId" class="form-label fw-bold">Модел</label>
                <select asp-for="ModelId" class="form-select" asp-items="ViewBag.ModelId"></select>
            </div>
            <div class="col-md-6">
                <label asp-for="ProductTypeId" class="form-label fw-bold">Категория</label>
                <select asp-for="ProductTypeId" class="form-select" asp-items="ViewBag.ProductTypeId"></select>
            </div>
            <div class="col-md-8">
                <label asp-for="ImageURL" class="form-label fw-bold">Снимка URL</label>
                <input asp-for="ImageURL" class="form-control" />
                <span asp-validation-for="ImageURL" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Price" class="form-label fw-bold">Цена</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label fw-bold">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-check2-circle me-2"></i>Създай
            </button>
            <a asp-action="Index" class="btn btn-outline-dark">Назад</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
