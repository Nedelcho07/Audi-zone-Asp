@model Audi_zone.Models.Product

@{
    ViewData["Title"] = "Изтриване на част";
}

<div class="page-heading mb-4">
    <span class="eyebrow">Админ</span>
    <h1 class="h2 mb-1">Изтриване на част</h1>
    <p class="text-muted mb-0">Потвърди премахването на продукта от каталога.</p>
</div>

<div class="surface p-4">
    <div class="alert alert-warning border-0 mb-4">
        <i class="bi bi-exclamation-triangle me-2"></i>Сигурен ли си, че искаш да изтриеш тази част?
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-md-4">
            <img src="@(string.IsNullOrWhiteSpace(Model.ImageURL) ? "https://via.placeholder.com/500x380?text=Audi+Part" : Model.ImageURL)"
                 alt="@Model.Name"
                 class="product-detail-image rounded" />
        </div>
        <div class="col-md-8">
            <h2 class="h4 mb-3">@Model.Name</h2>
            <div class="detail-stat-grid mb-4">
                <div class="detail-stat">
                    <span>Код</span>
                    <strong>@Model.Code</strong>
                </div>
                <div class="detail-stat">
                    <span>Модел</span>
                    <strong>@Model.Models?.ModelName</strong>
                </div>
                <div class="detail-stat">
                    <span>Категория</span>
                    <strong>@Model.ProductTypes?.Name</strong>
                </div>
                <div class="detail-stat">
                    <span>Цена</span>
                    <strong>@Model.Price.ToString("F2") лв.</strong>
                </div>
            </div>

            <form asp-action="Delete" class="form-actions">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-2"></i>Изтрий
                </button>
                <a asp-action="Index" class="btn btn-outline-dark">Назад</a>
            </form>
        </div>
    </div>
</div>
