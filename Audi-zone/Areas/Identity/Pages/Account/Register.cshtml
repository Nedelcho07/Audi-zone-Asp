@page
@model RegisterModel

@{
    ViewData["Title"] = "Регистрирайте се";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white text-center py-4 border-bottom-danger">
                    <h3 class="mb-2">
                        <i class="bi bi-car-front-fill me-2"></i>Audi-zone
                    </h3>
                    <p class="mb-0 text-danger fw-bold">Създай нов профил</p>
                </div>

                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        <strong><i class="bi bi-exclamation-circle me-2"></i>Грешка при регистрация!</strong>
                    </div>

                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Input.UserName" class="form-label fw-bold">
                                    <i class="bi bi-person me-2 text-danger"></i>Потребителско име
                                </label>
                                <input asp-for="Input.UserName"
                                       class="form-control form-control-lg border-2"
                                       autocomplete="username"
                                       aria-required="true"
                                       placeholder="Уникално потребителско име" />
                                <span asp-validation-for="Input.UserName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.FirstName" class="form-label fw-bold">
                                    <i class="bi bi-person-fill me-2 text-danger"></i>Име
                                </label>
                                <input asp-for="Input.FirstName"
                                       class="form-control form-control-lg border-2"
                                       autocomplete="given-name"
                                       aria-required="true"
                                       placeholder="Твоето име" />
                                <span asp-validation-for="Input.FirstName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.LastName" class="form-label fw-bold">
                                    <i class="bi bi-person-fill me-2 text-danger"></i>Фамилия
                                </label>
                                <input asp-for="Input.LastName"
                                       class="form-control form-control-lg border-2"
                                       autocomplete="family-name"
                                       aria-required="true"
                                       placeholder="Твоята фамилия" />
                                <span asp-validation-for="Input.LastName" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label fw-bold">
                                <i class="bi bi-envelope me-2 text-danger"></i>Имейл
                            </label>
                            <input asp-for="Input.Email"
                                   class="form-control form-control-lg border-2"
                                   autocomplete="email"
                                   aria-required="true"
                                   placeholder="твоя.имейл@example.com"
                                   type="email" />
                            <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.PhoneNumber" class="form-label fw-bold">
                                <i class="bi bi-telephone me-2 text-danger"></i>Телефонен номер
                            </label>
                            <input asp-for="Input.PhoneNumber"
                                   class="form-control form-control-lg border-2"
                                   autocomplete="tel"
                                   aria-required="true"
                                   placeholder="0888888888"
                                   type="tel" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label fw-bold">
                                <i class="bi bi-lock me-2 text-danger"></i>Парола
                            </label>
                            <input asp-for="Input.Password"
                                   class="form-control form-control-lg border-2"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Въведи силна парола"
                                   type="password" />
                            <small class="text-muted d-block mt-1">
                                <i class="bi bi-info-circle me-1"></i>Минимум 6 символа, с число и специален знак
                            </small>
                            <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword" class="form-label fw-bold">
                                <i class="bi bi-lock-fill me-2 text-danger"></i>Потвърди парола
                            </label>
                            <input asp-for="Input.ConfirmPassword"
                                   class="form-control form-control-lg border-2"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Повтори паролата"
                                   type="password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <button id="registerSubmit" type="submit" class="btn btn-danger btn-lg w-100 fw-bold mb-3">
                            <i class="bi bi-person-plus me-2"></i>Създай профил
                        </button>

                        <hr class="my-4">

                        <div class="text-center">
                            <p class="text-muted mb-2">Вече имаш профил?</p>
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-outline-dark fw-bold">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Влез в профила
                            </a>
                        </div>
                    </form>
                </div>

                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <div class="card-footer bg-light">
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <p class="text-center text-muted mb-3 small">Или регистрирай се чрез</p>
                            <div class="d-grid gap-2">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit"
                                            class="btn btn-outline-secondary"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Регистрирай се с @provider.DisplayName">
                                        <i class="bi bi-globe me-2"></i>@provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    </div>
                }
            </div>

            <div class="mt-4 p-4 bg-light rounded-3 border-start border-danger border-5">
                <h6 class="fw-bold text-dark mb-3">
                    <i class="bi bi-shield-check text-danger me-2"></i>Защо да се регистрираш?
                </h6>
                <ul class="small text-muted mb-0">
                    <li class="mb-2"><i class="bi bi-check-circle text-danger me-2"></i><strong>Безопасност:</strong> Защитени данни и сигурни покупки</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-danger me-2"></i><strong>Проследяване:</strong> Виж статуса на твоите поръчки</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-danger me-2"></i><strong>Препоръки:</strong> Персонализирани предложения</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-danger me-2"></i><strong>История:</strong> Всички твои покупки на едно място</li>
                    <li><i class="bi bi-check-circle text-danger me-2"></i><strong>Поддръжка:</strong> Достъп до помощ и консултации</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
