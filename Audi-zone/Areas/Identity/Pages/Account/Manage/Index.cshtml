@page
@model Audi_zone.Areas.Identity.Pages.Account.Manage.IndexModel

@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Моят профил";
    var displayName = string.Join(" ", new[] { Model.Input.FirstName, Model.Input.LastName }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim();
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = Model.Username;
    }

    var initials = string.Join("", displayName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(x => x[0]))
        .ToUpperInvariant();

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "AZ";
    }
}

<section class="account-manage-page">
    <div class="account-hero d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-3 p-4 mb-3 text-white bg-dark rounded-3 shadow">
        <div class="account-identity d-flex align-items-center gap-3">
            <div class="account-avatar d-inline-flex align-items-center justify-content-center flex-shrink-0 bg-danger rounded-3 fw-bold fs-4" style="width: 76px; height: 76px;" aria-hidden="true">@initials</div>
            <div>
                <span class="eyebrow"><i class="bi bi-person-gear"></i> Потребителски профил</span>
                <h1 class="mb-1 fw-bold">@displayName</h1>
                <p class="mb-0 text-white-50">@Model.Email</p>
            </div>
        </div>
        <div class="account-hero-actions d-flex flex-wrap gap-2">
            <a class="btn btn-light" asp-controller="Carts" asp-action="Orders">
                <i class="bi bi-bag-check me-2"></i>Поръчки
            </a>
            <a class="btn btn-danger" asp-controller="Carts" asp-action="Index">
                <i class="bi bi-cart3 me-2"></i>Количка
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success account-alert shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@Model.StatusMessage
        </div>
    }

    <div class="account-layout row g-3 align-items-start">
        <aside class="account-sidebar col-lg-3 bg-white border rounded-3 shadow-sm p-2">
            <partial name="_ManageNav" />
        </aside>

        <div class="account-main col-lg-9 d-grid gap-3">
            <div class="account-panel bg-white border rounded-3 shadow-sm p-4">
                <div class="account-panel-header d-flex flex-column flex-md-row align-items-start justify-content-between gap-3 pb-3 mb-4 border-bottom">
                    <div>
                        <span class="eyebrow"><i class="bi bi-pencil-square"></i> Основни данни</span>
                        <h2 class="mb-0 fw-bold">Настройки на профила</h2>
                    </div>
                    <span class="account-state d-inline-flex align-items-center gap-2 px-3 py-2 text-success bg-success-subtle rounded-pill fw-bold">
                        <i class="bi bi-shield-check"></i>
                        Активен профил
                    </span>
                </div>

                <form id="profile-form" method="post" class="account-form">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="account-readonly-grid row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="account-readonly-field bg-light border rounded-3 p-3 h-100">
                            <span><i class="bi bi-person-badge"></i> Потребителско име</span>
                            <strong>@Model.Username</strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="account-readonly-field bg-light border rounded-3 p-3 h-100">
                            <span><i class="bi bi-envelope"></i> Имейл</span>
                            <strong>@Model.Email</strong>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.FirstName" class="form-label"></label>
                            <input asp-for="Input.FirstName" class="form-control form-control-lg" autocomplete="given-name" />
                            <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.LastName" class="form-label"></label>
                            <input asp-for="Input.LastName" class="form-control form-control-lg" autocomplete="family-name" />
                            <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-7">
                            <label asp-for="Input.PhoneNumber" class="form-label"></label>
                            <input asp-for="Input.PhoneNumber" class="form-control form-control-lg" autocomplete="tel" />
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="account-form-actions d-flex justify-content-end mt-4">
                        <button id="update-profile-button" type="submit" class="btn btn-danger btn-lg">
                            <i class="bi bi-save me-2"></i>Запази промените
                        </button>
                    </div>
                </form>
            </div>

            <div class="account-stats row g-3">
                <a class="account-stat col-md bg-white border rounded-3 shadow-sm p-3 text-decoration-none text-dark d-flex align-items-center gap-3" asp-controller="Carts" asp-action="Index">
                    <span class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-3 fs-4" style="width: 48px; height: 48px;"><i class="bi bi-cart3"></i></span>
                    <span>
                        <small class="d-block text-muted fw-bold text-uppercase">В количката</small>
                        <strong class="fs-5">@Model.CartItemsCount</strong>
                    </span>
                </a>
                <a class="account-stat col-md bg-white border rounded-3 shadow-sm p-3 text-decoration-none text-dark d-flex align-items-center gap-3" asp-controller="Carts" asp-action="Orders">
                    <span class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-3 fs-4" style="width: 48px; height: 48px;"><i class="bi bi-bag-check"></i></span>
                    <span>
                        <small class="d-block text-muted fw-bold text-uppercase">Поръчки</small>
                        <strong class="fs-5">@Model.OrdersCount</strong>
                    </span>
                </a>
                <div class="account-stat col-md bg-white border rounded-3 shadow-sm p-3 d-flex align-items-center gap-3">
                    <span class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-3 fs-4" style="width: 48px; height: 48px;"><i class="bi bi-receipt"></i></span>
                    <span>
                        <small class="d-block text-muted fw-bold text-uppercase">Общо покупки</small>
                        <strong class="fs-5">@Model.OrdersTotal.ToString("F2") лв.</strong>
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
