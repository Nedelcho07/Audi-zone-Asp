@page
@model LogoutModel

@{
    ViewData["Title"] = "Изход";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white text-center py-4 border-bottom-danger">
                    <h3 class="mb-2">
                        <i class="bi bi-car-front-fill me-2"></i>Audi-zone
                    </h3>
                    <p class="mb-0 text-danger fw-bold">Сигурно излизане от профила</p>
                </div>

                <div class="card-body p-4 text-center">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <i class="bi bi-box-arrow-right text-danger profile-icon"></i>
                        <h4 class="mt-3">Искаш ли да излезеш?</h4>
                        <p class="text-muted mb-4">Ще трябва да влезеш отново, за да управляваш количката и поръчките си.</p>

                        <form method="post">
                            <button type="submit" class="btn btn-danger btn-lg px-4 fw-bold">
                                <i class="bi bi-door-open me-2"></i>Изход
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark btn-lg px-4 ms-2 fw-bold">Отказ</a>
                        </form>
                    }
                    else
                    {
                        <i class="bi bi-check-circle text-success profile-icon"></i>
                        <h4 class="mt-3">Успешно излязохте от профила</h4>
                        <p class="text-muted mb-4">Благодарим, че използвате Audi-zone.</p>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-dark px-4 fw-bold">Към началната страница</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
