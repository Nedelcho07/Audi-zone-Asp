@page
@model LoginModel

@{
    ViewData["Title"] = "Влез в профила";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white text-center py-4 border-bottom-danger">
                    <h3 class="mb-2">
                        <i class="bi bi-car-front-fill me-2"></i>Audi-zone
                    </h3>
                    <p class="mb-0 text-danger fw-bold">Влезте в своя профил</p>
                </div>

                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger alert-dismissible fade show" role="alert">
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        <strong><i class="bi bi-exclamation-circle me-2"></i>Грешка при влизане!</strong>
                    </div>

                    <form id="account" method="post">
                        <div class="mb-3">
                            <label asp-for="Input.UserName" class="form-label fw-bold">
                                <i class="bi bi-person me-2 text-danger"></i>Потребителско име
                            </label>
                            <input asp-for="Input.UserName"
                                   class="form-control form-control-lg border-2"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="Въведи потребителското си име" />
                            <span asp-validation-for="Input.UserName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label fw-bold">
                                <i class="bi bi-lock me-2 text-danger"></i>Парола
                            </label>
                            <input asp-for="Input.Password"
                                   class="form-control form-control-lg border-2"
                                   autocomplete="current-password"
                                   aria-required="true"
                                   placeholder="Въведи своята парола"
                                   type="password" />
                            <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" asp-for="Input.RememberMe" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">Запомни ме</label>
                        </div>

                        <button id="login-submit" type="submit" class="btn btn-danger btn-lg w-100 fw-bold mb-3">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Влез
                        </button>

                        <hr class="my-4">

                        <div class="text-center mb-3">
                            <p class="text-muted mb-2">Нямаш профил?</p>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-outline-dark fw-bold">
                                <i class="bi bi-person-plus me-2"></i>Създай профил
                            </a>
                        </div>
                    </form>
                </div>

                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <div class="card-footer bg-light">
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <p class="text-center text-muted mb-3 small">Или влез чрез</p>
                            <div class="d-grid gap-2">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit"
                                            class="btn btn-outline-secondary"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Влез с @provider.DisplayName">
                                        <i class="bi bi-globe me-2"></i>@provider.DisplayName
                                    </button>
                                }
                            </div>
                        </form>
                    </div>
                }
            </div>

            <div class="mt-4 p-4 bg-light rounded-3 border-start border-danger border-5">
                <h6 class="fw-bold text-dark mb-2">
                    <i class="bi bi-info-circle text-danger me-2"></i>Защо да се регистрираш?
                </h6>
                <ul class="small text-muted mb-0">
                    <li><i class="bi bi-check-circle text-danger me-2"></i>Безопасни покупки</li>
                    <li><i class="bi bi-check-circle text-danger me-2"></i>Проследяване на поръчки</li>
                    <li><i class="bi bi-check-circle text-danger me-2"></i>Персонализирани препоръки</li>
                    <li><i class="bi bi-check-circle text-danger me-2"></i>История на покупките</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
