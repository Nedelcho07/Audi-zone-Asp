@page
@model Audi_zone.Areas.Identity.Pages.Admin.DashboardModel

@{
    ViewData["Title"] = "Админ панел";
}

<div class="admin-dashboard">
    <section class="admin-hero">
        <div>
            <span class="eyebrow">Audi-zone</span>
            <h1 class="mb-2">Админ панел</h1>
            <p class="mb-0">Управление на каталог, модели, категории и поръчки.</p>
        </div>
        <div class="admin-hero-actions">
            <a asp-controller="Products" asp-action="Create" class="btn btn-danger">
                <i class="bi bi-plus-circle me-2"></i>Нова част
            </a>
            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-light">
                <i class="bi bi-eye me-2"></i>Публичен каталог
            </a>
        </div>
    </section>

    <section class="admin-stats-grid">
        <div class="admin-stat">
            <span class="admin-stat-icon"><i class="bi bi-box2"></i></span>
            <div>
                <p>Общо части</p>
                <strong>@Model.TotalProducts</strong>
            </div>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-icon"><i class="bi bi-car-front"></i></span>
            <div>
                <p>Модели</p>
                <strong>@Model.TotalModels</strong>
            </div>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-icon"><i class="bi bi-tags"></i></span>
            <div>
                <p>Категории</p>
                <strong>@Model.TotalProductTypes</strong>
            </div>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-icon"><i class="bi bi-bag-check"></i></span>
            <div>
                <p>Поръчки</p>
                <strong>@Model.TotalOrders</strong>
            </div>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-icon"><i class="bi bi-people"></i></span>
            <div>
                <p>Потребители</p>
                <strong>@Model.TotalClients</strong>
            </div>
        </div>
        <div class="admin-stat">
            <span class="admin-stat-icon"><i class="bi bi-cash-coin"></i></span>
            <div>
                <p>Оборот поръчки</p>
                <strong>@Model.TotalOrdersValue.ToString("F2") лв.</strong>
            </div>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-xl-8">
            <section class="admin-panel">
                <div class="admin-panel-header">
                    <div>
                        <span class="eyebrow">Каталог</span>
                        <h2 class="h4 mb-0">Последни продукти</h2>
                    </div>
                    <a asp-controller="Products" asp-action="Create" class="btn btn-sm btn-danger">
                        <i class="bi bi-plus-circle me-1"></i>Добави
                    </a>
                </div>

                @if (Model.RecentProducts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-modern align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Име</th>
                                    <th>Модел</th>
                                    <th>Категория</th>
                                    <th class="text-end">Цена</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in Model.RecentProducts)
                                {
                                    <tr>
                                        <td>
                                            <strong>@product.Name</strong>
                                            <div class="small text-muted">@product.Code</div>
                                        </td>
                                        <td>@product.Models?.ModelName</td>
                                        <td>@product.ProductTypes?.Name</td>
                                        <td class="text-end fw-bold text-danger">@product.Price.ToString("F2") лв.</td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <a asp-controller="Products" asp-action="Edit" asp-route-id="@product.Id" class="btn btn-outline-dark" title="Редактирай">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a asp-controller="Products" asp-action="Delete" asp-route-id="@product.Id" class="btn btn-outline-danger" title="Изтрий">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state compact">Няма добавени части.</div>
                }
            </section>
        </div>

        <div class="col-xl-4">
            <section class="admin-panel">
                <div class="admin-panel-header">
                    <div>
                        <span class="eyebrow">Поръчки</span>
                        <h2 class="h4 mb-0">Всички поръчки</h2>
                    </div>
                </div>

                @if (Model.RecentOrders.Any())
                {
                    <div class="order-list">
                        @foreach (var order in Model.RecentOrders)
                        {
                            <a asp-controller="Carts" asp-action="OrderDetails" asp-route-id="@order.Id" class="order-list-item">
                                <span>
                                    <strong>#@order.Id</strong>
                                    <small>@(order.Client?.Email ?? order.ClientId)</small>
                                </span>
                                <span class="text-end">
                                    <strong>@order.TotalPrice.ToString("F2") лв.</strong>
                                    <small>@order.OrderedOn.ToString("dd.MM.yyyy")</small>
                                </span>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state compact">Няма направени поръчки.</div>
                }
            </section>
        </div>

        <div class="col-lg-6">
            <section class="admin-panel">
                <div class="admin-panel-header">
                    <div>
                        <span class="eyebrow">Автомобили</span>
                        <h2 class="h4 mb-0">Модели</h2>
                    </div>
                    <a asp-controller="Models" asp-action="Index" class="btn btn-sm btn-outline-dark">Управлявай</a>
                </div>

                @if (Model.AllModels.Any())
                {
                    <div class="admin-list">
                        @foreach (var carModel in Model.AllModels.Take(5))
                        {
                            <div class="admin-list-item">
                                <span>@carModel.ModelName</span>
                                <div class="btn-group btn-group-sm">
                                    <a asp-controller="Models" asp-action="Edit" asp-route-id="@carModel.Id" class="btn btn-outline-dark" title="Редактирай">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="Models" asp-action="Delete" asp-route-id="@carModel.Id" class="btn btn-outline-danger" title="Изтрий">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state compact">Няма модели.</div>
                }
            </section>
        </div>

        <div class="col-lg-6">
            <section class="admin-panel">
                <div class="admin-panel-header">
                    <div>
                        <span class="eyebrow">Каталог</span>
                        <h2 class="h4 mb-0">Категории</h2>
                    </div>
                    <a asp-controller="ProductTypes" asp-action="Index" class="btn btn-sm btn-outline-dark">Управлявай</a>
                </div>

                @if (Model.AllProductTypes.Any())
                {
                    <div class="admin-list">
                        @foreach (var type in Model.AllProductTypes.Take(5))
                        {
                            <div class="admin-list-item">
                                <span>@type.Name</span>
                                <div class="btn-group btn-group-sm">
                                    <a asp-controller="ProductTypes" asp-action="Edit" asp-route-id="@type.Id" class="btn btn-outline-dark" title="Редактирай">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="ProductTypes" asp-action="Delete" asp-route-id="@type.Id" class="btn btn-outline-danger" title="Изтрий">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state compact">Няма категории.</div>
                }
            </section>
        </div>
    </div>
</div>
